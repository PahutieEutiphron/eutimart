<%- include('partials/header') %>

<section class="checkout-section">
    <h1>Checkout</h1>

    <div class="checkout-grid">
        <div class="checkout-form-container">
            <h2>Payment Details</h2>
            <p class="checkout-note">You can use any test card details for this demo.</p>

            <form action="/checkout" method="POST" class="checkout-form" id="checkoutForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <% if (typeof cart !== 'undefined' && cart && cart.items) { %>
                    <% cart.items.forEach(function(item, idx) { %>
                        <input type="hidden" name="items[<%= idx %>][productId]" value="<%= item.productId %>">
                        <input type="hidden" name="items[<%= idx %>][quantity]" value="<%= item.quantity %>">
                        <input type="hidden" name="items[<%= idx %>][price]" value="<%= item.price %>">
                    <% }); %>
                <% } %>

                <div class="form-group">
                    <label for="cardHolder">Cardholder Name</label>
                    <input type="text" id="cardHolder" name="cardHolder" placeholder="John Doe" required autocomplete="cc-name">
                </div>

                <div class="form-group">
                    <label for="cardNumber">Card Number</label>
                    <input type="text" id="cardNumber" name="cardNumber" placeholder="4242 4242 4242 4242" required maxlength="19" autocomplete="cc-number">
                </div>

                <div class="form-row-2col">
                    <div class="form-group">
                        <label for="expiry">Expiry Date</label>
                        <input type="text" id="expiry" name="expiry" placeholder="MM/YY" required maxlength="5" autocomplete="cc-exp">
                    </div>
                    <div class="form-group">
                        <label for="cvv">CVV</label>
                        <input type="text" id="cvv" name="cvv" placeholder="123" required maxlength="4" autocomplete="cc-csc">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-block btn-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                        <line x1="1" y1="10" x2="23" y2="10"></line>
                    </svg>
                    Place Order
                </button>
            </form>
        </div>

        <div class="order-summary">
            <h2>Order Summary</h2>
            <div class="order-items">
                <% if (typeof cart !== 'undefined' && cart && cart.items && cart.items.length > 0) { %>
                    <% cart.items.forEach(function(item) { %>
                        <div class="order-item">
                            <div class="order-item-info">
                                <span class="order-item-name"><%= item.name %></span>
                                <span class="order-item-qty">x<%= item.quantity %></span>
                            </div>
                            <span class="order-item-price">$<%= (item.price * item.quantity).toFixed(2) %></span>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="cart-empty">No items in cart.</p>
                <% } %>
            </div>
            <div class="order-divider"></div>
            <div class="order-total">
                <span>Total</span>
                <span class="order-total-price">$<%= (typeof cart !== 'undefined' && cart) ? cart.total.toFixed(2) : '0.00' %></span>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const cardNumber = document.getElementById('cardNumber');
    if (cardNumber) {
        cardNumber.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            let formatted = value.match(/.{1,4}/g);
            e.target.value = formatted ? formatted.join(' ') : '';
        });
    }
    const expiry = document.getElementById('expiry');
    if (expiry) {
        expiry.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 2) {
                value = value.substring(0, 2) + '/' + value.substring(2);
            }
            e.target.value = value;
        });
    }
});
</script>

<%- include('partials/footer') %>
